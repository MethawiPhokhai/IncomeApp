{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "IncomeApp"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "BackendUrl": "http://localhost:5098",
    "FrontendUrl": "https://localhost:5173"
  },
  "Jwt": {
    "Key": "super_secret_key_for_development_purpose_only_very_long_string",
    "Issuer": "http://localhost:5098",
    "Audience": "https://localhost:5173"
  }
}
