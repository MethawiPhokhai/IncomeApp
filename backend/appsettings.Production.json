{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "IncomeApp": "Information",
        "backend": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "BackendUrl": "https://incomeapp-production.up.railway.app",
    "FrontendUrl": "https://incomeappproduction.netlify.app"
  },
  "Jwt": {
    "Key": "super_secret_key_for_development_purpose_only_very_long_string",
    "Issuer": "https://incomeapp-production.up.railway.app",
    "Audience": "https://incomeappproduction.netlify.app"
  }
}
